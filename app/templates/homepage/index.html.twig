{% extends 'base.html.twig' %}

{% block title %}System biblioteczny - API{% endblock %}

{% block stylesheets %}
<style>
    :root {
        color-scheme: light dark;
        --fg: #282f55;
        --muted: #45455e;
        --border: #eceeef;
        --bg: #fff;
        --code-bg: #f1f1f1;
        --accent: #7f549e;
    }

    @media (prefers-color-scheme: dark) {
        :root {
            --fg: #f1f1f1;
            --muted: #b8b6c4;
            --border: #3a3a4a;
            --bg: #1c1c26;
            --code-bg: #262631;
            --accent: #b48cc9;
        }
    }

    * { box-sizing: border-box; }

    body {
        margin: 0;
        padding: 1.5rem 1rem 3rem;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.5;
    }

    main {
        max-width: 40rem;
        margin: 0 auto;
    }

    h1 {
        font-size: 1.4rem;
        margin-bottom: 0.25rem;
        color: var(--accent);
    }

    p.lead {
        color: var(--muted);
        margin-top: 0;
    }

    code {
        background: var(--code-bg);
        padding: 0.1rem 0.35rem;
        border-radius: 0.25rem;
        font-size: 0.9em;
    }

    code.method {
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        color: var(--accent);
        font-weight: 600;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.9rem;
    }

    caption {
        text-align: left;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--fg);
    }

    th, td {
        text-align: left;
        padding: 0.5rem 0.6rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
    }

    th {
        color: var(--muted);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    footer {
        margin-top: 2rem;
        color: var(--muted);
        font-size: 0.85rem;
    }

    @media (max-width: 30rem) {
        table, thead, tbody, tr, th, td { display: block; }
        thead { display: none; }
        tr {
            border-bottom: 1px solid var(--border);
            padding: 0.5rem 0;
        }
        td {
            border: none;
            padding: 0.15rem 0;
        }
        td::before {
            content: attr(data-label);
            display: block;
            color: var(--muted);
            font-size: 0.75rem;
            text-transform: uppercase;
        }
    }
</style>
{% endblock %}

{% block body %}
<main>
    <h1>System biblioteczny - API</h1>
    <p class="lead">
        Proste JSON API do zarządzania książkami w bibliotece: dodawanie, usuwanie,
        lista i wypożyczanie/zwrot. Bez uwierzytelniania.
    </p>

    <table>
        <caption>Endpointy</caption>
        <thead>
            <tr>
                <th>Metoda</th>
                <th>Ścieżka</th>
                <th>Opis</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td data-label="Metoda"><code class="method">GET</code></td>
                <td data-label="Ścieżka"><code>/books</code></td>
                <td data-label="Opis">Lista wszystkich książek</td>
            </tr>
            <tr>
                <td data-label="Metoda"><code class="method">POST</code></td>
                <td data-label="Ścieżka"><code>/books</code></td>
                <td data-label="Opis">Dodanie nowej książki</td>
            </tr>
            <tr>
                <td data-label="Metoda"><code class="method">DELETE</code></td>
                <td data-label="Ścieżka"><code>/books/{serialNumber}</code></td>
                <td data-label="Opis">Usunięcie książki</td>
            </tr>
            <tr>
                <td data-label="Metoda"><code class="method">POST</code></td>
                <td data-label="Ścieżka"><code>/books/{serialNumber}/borrow</code></td>
                <td data-label="Opis">Wypożyczenie książki</td>
            </tr>
            <tr>
                <td data-label="Metoda"><code class="method">POST</code></td>
                <td data-label="Ścieżka"><code>/books/{serialNumber}/return</code></td>
                <td data-label="Opis">Zwrot książki</td>
            </tr>
        </tbody>
    </table>

    <footer>
        Pełna dokumentacja, przykłady requestów i kontrakt błędów - w
        <code>README.md</code> repozytorium.
    </footer>
</main>
{% endblock %}
